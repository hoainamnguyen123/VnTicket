server:
  port: 8080

spring:
  application:
    name: vnticket-backend
  datasource:
    url: jdbc:postgresql://localhost:5432/vnticket
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: org.postgresql.Driver
  data:
    redis:
      host: localhost
      port: 6379
  jpa:
    hibernate:
      ddl-auto: update
    properties:
      hibernate:
        format_sql: true

app:
  jwt:
    secret: YOUR_JWT_SECRET_KEY_MUST_BE_AT_LEAST_64_CHARS_LONG
    expirationMs: 600000         # 10 phút
    jwtRefreshExpirationMs: 2592000000  # 30 ngày
  google:
    clientId: YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
  vnpay:
    tmnCode: YOUR_VNPAY_TMN_CODE
    hashSecret: YOUR_VNPAY_HASH_SECRET
    payUrl: https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
    returnUrl: http://localhost:5173/payment-return
